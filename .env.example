# Required bot runtime
BOT_1_TOKEN=your_discord_bot_token
BOT_1_CLIENT_ID=your_discord_application_id
BOT_1_NAME=OmniFM Commander
BOT_1_TIER=free

# Additional bots follow the same pattern:
# BOT_2_TOKEN=
# BOT_2_CLIENT_ID=
# BOT_2_NAME=OmniFM Worker 2
# BOT_2_TIER=free

# Topology and command registration
COMMANDER_BOT_INDEX=1
OMNIFM_DEPLOYMENT_MODE=auto
COMMAND_REGISTRATION_MODE=guild
PERIODIC_GUILD_COMMAND_SYNC_MS=1800000
CLEAN_GLOBAL_COMMANDS_ON_BOOT=1
CLEAN_GUILD_COMMANDS_ON_BOOT=0
CLEAN_WORKER_GUILD_COMMANDS_ON_BOOT=1

# Web / API
WEB_PORT=8081
WEB_INTERNAL_PORT=8080
PUBLIC_WEB_URL=http://localhost:8081
WEB_DOMAIN=
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
CHECKOUT_RETURN_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
API_ADMIN_TOKEN=change-me
TRUST_PROXY_HEADERS=1

# Language
DEFAULT_LANGUAGE=en

# Dashboard OAuth
DISCORD_CLIENT_ID=your_dashboard_client_id
DISCORD_CLIENT_SECRET=your_dashboard_client_secret
DISCORD_REDIRECT_URI=http://localhost:8081/api/auth/discord/callback
DISCORD_OAUTH_SCOPES=identify guilds
DASHBOARD_SESSION_COOKIE=omnifm_session
DASHBOARD_SESSION_TTL_SECONDS=86400
DISCORD_OAUTH_STATE_TTL_SECONDS=600

# Premium / billing / email
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PRO_TRIAL_ENABLED=1
EXPIRY_REMINDER_DAYS=30,14,7,1
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_EMAIL=

# MongoDB / storage / logs
# Split mode requires MongoDB. Monolith mode can use file-backed fallback stores.
# For split Docker deployments keep MONGO_URL=mongodb://mongodb:27017 or MONGO_ENABLED=1.
MONGO_ENABLED=0
MONGO_URL=
DB_NAME=radio_bot
LOGS_DIR=logs
LOG_MAX_MB=5
LOG_MAX_FILES=30
LOG_MAX_DAYS=14
BOT_STATE_SPLIT_DIR=bot-state

# Playback / metadata
NOW_PLAYING_ENABLED=1
NOW_PLAYING_COVER_ENABLED=1
SONG_HISTORY_ENABLED=1
SONG_HISTORY_MAX_PER_GUILD=50

# Audio recognition
NOW_PLAYING_RECOGNITION_ENABLED=0
ACOUSTID_API_KEY=
NOW_PLAYING_MUSICBRAINZ_ENABLED=1
NOW_PLAYING_RECOGNITION_SAMPLE_SECONDS=18
NOW_PLAYING_RECOGNITION_MIN_SECONDS=10
NOW_PLAYING_RECOGNITION_TIMEOUT_MS=28000
NOW_PLAYING_RECOGNITION_CAPTURE_RETRIES=2
NOW_PLAYING_RECOGNITION_CAPTURE_SAMPLE_RATE=44100
NOW_PLAYING_RECOGNITION_CAPTURE_CHANNELS=2
NOW_PLAYING_RECOGNITION_SCORE_THRESHOLD=0.55

# Voice / reliability
PREMIUM_GUILD_ACCESS_MODE=restrict
VOICE_CHANNEL_STATUS_ENABLED=1
VOICE_CHANNEL_STATUS_TEMPLATE=🔊 | 24/7 {station}
VOICE_CHANNEL_STATUS_REFRESH_MS=900000
VOICE_STATE_RECONCILE_ENABLED=1
VOICE_STATE_RECONCILE_MS=30000
VOICE_MOVE_POLICY=return
VOICE_MOVE_CONFIRMATIONS=2
VOICE_MOVE_RETURN_COOLDOWN_MS=15000
VOICE_MOVE_WINDOW_MS=120000
VOICE_MOVE_MAX_EVENTS_PER_WINDOW=4
VOICE_MOVE_ESCALATION=disconnect
VOICE_MOVE_ESCALATION_COOLDOWN_MS=600000
VOICE_TRANSIENT_RECHECK_MS=5000
VOICE_STATE_MISSING_CONFIRMATIONS=2
VOICE_RECONNECT_RESOURCE_CONFIRMATIONS=3
VOICE_RECONNECT_CIRCUIT_BREAKER_ATTEMPTS=30
VOICE_RECONNECT_CIRCUIT_BREAKER_MS=900000
VOICE_RECONNECT_MAX_MS=120000
STREAM_RESTART_BASE_MS=1000
STREAM_RESTART_MAX_MS=120000
STREAM_ERROR_COOLDOWN_THRESHOLD=8
STREAM_ERROR_COOLDOWN_MS=60000
DNS_LOOKUP_RETRY_COUNT=3
DNS_LOOKUP_RETRY_DELAY_MS=750
DNS_LOOKUP_CACHE_TTL_MS=600000
DNS_LOOKUP_STALE_TTL_MS=3600000

# Split runtime / remote workers
REMOTE_WORKER_HEARTBEAT_MS=5000
REMOTE_WORKER_COMMAND_POLL_MS=1000
REMOTE_WORKER_COMMAND_TTL_MS=300000
REMOTE_WORKER_STATUS_POLL_MS=2000
REMOTE_WORKER_STATUS_STALE_MS=45000
UPDATE_STRATEGY=rolling
UPDATE_ROLLING_DELAY_MS=15000
UPDATE_ROLLING_WAIT_TIMEOUT_MS=120000
WORKER_AUTOHEAL_ENABLED=1
WORKER_AUTOHEAL_CHECK_MS=30000
WORKER_AUTOHEAL_GRACE_MS=600000
WORKER_AUTOHEAL_RECOVERING_MS=1200000

# DiscordBotList / discordbotlist.com
DISCORDBOTLIST_ENABLED=0
DISCORDBOTLIST_TOKEN=
DISCORDBOTLIST_BOT_ID=
DISCORDBOTLIST_SLUG=
DISCORDBOTLIST_WEBHOOK_SECRET=
DISCORDBOTLIST_STATS_SCOPE=aggregate
DISCORDBOTLIST_COMMANDS_SYNC_MS=21600000
DISCORDBOTLIST_STATS_SYNC_MS=1800000
DISCORDBOTLIST_VOTE_SYNC_MS=1800000

# discord.bots.gg
BOTSGG_ENABLED=0
BOTSGG_TOKEN=
BOTSGG_BOT_ID=
BOTSGG_STATS_SCOPE=aggregate
BOTSGG_STARTUP_DELAY_MS=15000
BOTSGG_STATS_SYNC_MS=1800000

# Top.gg
TOPGG_ENABLED=0
TOPGG_TOKEN=
TOPGG_BOT_ID=
TOPGG_WEBHOOK_SECRET=
TOPGG_STATS_SCOPE=aggregate
TOPGG_STARTUP_DELAY_MS=15000
TOPGG_PROJECT_SYNC_MS=21600000
TOPGG_COMMANDS_SYNC_MS=21600000
TOPGG_STATS_SYNC_MS=1800000
TOPGG_VOTE_SYNC_MS=1800000
TOPGG_VOTE_SYNC_START_DAYS=30

# Legal pages
